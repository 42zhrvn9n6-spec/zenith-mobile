{
  "expo": {
    "name": "Z Zenith",
    "slug": "zenith-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zenith",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060610"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zenith.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil fotoğrafı eklemek için kamera kullanımı",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı eklemek için galeri erişimi"
      }
    },
    "android": {
      "package": "com.zenith.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060610"
      },
      "permissions": ["NOTIFICATIONS", "CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
